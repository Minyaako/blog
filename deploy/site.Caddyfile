{
    admin off
    auto_https off
    persist_config off
}

:8080 {
    root * /srv
    encode zstd gzip

    respond /healthz "ok" 200

    @immutable path /_astro/* /pagefind/*
    header @immutable Cache-Control "public, max-age=31536000, immutable"
    header {
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
    }

    file_server
    handle_errors {
        rewrite * /404.html
        file_server
    }
}
