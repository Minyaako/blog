---
import { SITE } from '../config/site'
import AppIcon from './AppIcon.astro'
---

<footer class="site-footer" data-pagefind-ignore>
  <div class="site-shell footer-inner">
    <p class="footer-copy">
      © {new Date().getFullYear()} Minyako。原创文字采用 CC BY 4.0；第三方图像、游戏素材与商标归原权利人所有。
    </p>
    <ul class="social-list" aria-label="外部平台">
      {SITE.socials.map((social) => (
        <li>
          <a class="social-link" href={social.href} aria-label={social.label}>
            <AppIcon name={social.icon} />
          </a>
        </li>
      ))}
    </ul>
  </div>
</footer>
