{
  "name": "minyako-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:visual": "playwright test tests/e2e/visual.spec.ts",
    "test:deploy": "bash tests/deploy/blog-release.test.sh",
    "media:prepare": "media-publisher prepare --manifest media/media.yaml --lock media/media.lock.json",
    "media:validate": "media-publisher validate --manifest media/media.yaml --lock media/media.lock.json",
    "media:publish": "media-publisher publish --manifest media/media.yaml --lock media/media.lock.json --credentials github-oidc --bucket $MEDIA_COS_BUCKET --region $MEDIA_COS_REGION --report .media-publish-report.json",
    "media:verify": "media-publisher verify --lock media/media.lock.json --report .media-publish-report.json",
    "build:astro": "astro build",
    "build:search": "pagefind --site dist",
    "build": "pnpm check && pnpm test:unit && pnpm build:astro && pnpm build:search",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/mdx": "7.0.2",
    "@astrojs/rss": "4.0.19",
    "@astrojs/sitemap": "3.7.3",
    "@fontsource-variable/manrope": "5.2.8",
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@iconify-json/lucide": "1.2.116",
    "@iconify-json/simple-icons": "1.2.89",
    "astro": "7.0.7",
    "astro-icon": "1.1.5",
    "katex": "0.17.0",
    "pagefind": "1.5.2",
    "rehype-katex": "7.0.1",
    "remark-math": "6.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@minyaako/media-publisher": "github:Minyaako/media-publisher#48d975d6536852cc94aa96031cc99c2a75b81b8e",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  }
}
